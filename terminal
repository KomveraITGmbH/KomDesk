<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />

<style>
:root { --logo-size: 160px; }

html, body {
    margin: 0 !important;
    padding: 0 !important;
    height: 100%;
    width: 100%;
    background: #ffffff !important;
    font-family: Arial, sans-serif;
    overflow: hidden;
    box-sizing: border-box;
}
* { box-sizing: border-box; }

.logo {
    position: absolute;
    top: 16px; left: 20px;
    width: var(--logo-size);
    height: auto;
    z-index: 50;
}

.wrapper {
    display: flex;
    flex-direction: column;
    height: calc(100% + 2 * var(--gap, 16px));
    width: calc(100% + 2 * var(--gap, 16px));
    margin: calc(-1 * var(--gap, 16px));
}

.container {
    flex: 1;
    min-height: 0;
    background: #ffffff;
    padding: 24px 16px 16px 16px;
    width: 100%;
    border: 2px solid #000;
    border-radius: 0;
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
}

.date-box {
    position: absolute;
    right: 16px; top: 14px;
    border: 1px solid #000;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 13px;
}

.room-box {
    text-align: right;
    padding: 5px 8px;
    font-size: 14px;
    flex-shrink: 0;
    height: 28px;
}

h1 {
    margin: 0 0 10px 0;
    font-size: 22px;
    font-weight: 600;
    color: #333;
    flex-shrink: 0;
}

.grid {
    flex: 1;
    min-height: 0;
    display: grid;
    gap: 8px 12px;
    grid-auto-rows: 1fr;
}

.grid.cols-1 { grid-template-columns: 1fr; }
.grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
.grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
.grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
.grid.cols-5 { grid-template-columns: repeat(5, 1fr); }
.grid.cols-6 { grid-template-columns: repeat(6, 1fr); }

.box {
    border: 2px solid #000;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 0;
    padding: 5px 8px;
    overflow: hidden;
}

.box .name {
    font-weight: 700;
    color: #000;
    white-space: nowrap;
    line-height: 1.15;
    text-align: center;
    width: 100%;
}

.box .title {
    color: #000;
    margin-top: 3px;
    white-space: nowrap;
    line-height: 1.15;
    text-align: center;
    width: 100%;
}
</style>
</head>

<body>

<svg class="logo" viewBox="0 0 300 80">
    <circle cx="55" cy="40" r="22" fill="#000"></circle>
    <circle cx="20" cy="45" r="8" fill="#000"></circle>
    <text x="100" y="48" font-family="Arial, sans-serif" font-size="38" fill="#000">steinel</text>
</svg>

<div class="wrapper">
    <div class="container">
        <div id="dateBox" class="date-box"></div>
        <h1>{{ abteilung }}</h1>

        {% assign cnt = seats | size %}
        {% if    cnt == 1  %}{% assign cols = 'cols-1' %}
        {% elsif cnt == 2  %}{% assign cols = 'cols-2' %}
        {% elsif cnt == 3  %}{% assign cols = 'cols-3' %}
        {% elsif cnt == 4  %}{% assign cols = 'cols-2' %}
        {% elsif cnt <= 6  %}{% assign cols = 'cols-3' %}
        {% elsif cnt <= 8  %}{% assign cols = 'cols-4' %}
        {% elsif cnt <= 12 %}{% assign cols = 'cols-4' %}
        {% elsif cnt <= 15 %}{% assign cols = 'cols-5' %}
        {% elsif cnt == 16 %}{% assign cols = 'cols-4' %}
        {% elsif cnt <= 18 %}{% assign cols = 'cols-6' %}
        {% else            %}{% assign cols = 'cols-5' %}
        {% endif %}

        <div class="grid {{ cols }}">
            {% for seat in seats %}
            <div class="box">
                <div class="name">{{ seat.name | default: 'Frei' }}</div>
                <div class="title">{{ seat.title }}</div>
            </div>
            {% endfor %}
        </div>

    </div>
    <div class="room-box">{{ roomnumber }}</div>
</div>

<script>
document.getElementById("dateBox").textContent =
    new Date().toLocaleDateString("de-DE", { weekday:"long", year:"numeric", month:"long", day:"numeric" });

const gridEl  = document.querySelector('.grid');
const colMatch = gridEl.className.match(/cols-(\d)/);
const colCount = colMatch ? parseInt(colMatch[1]) : 3;

// Max-Schriftgröße und Umbruchschwelle je nach Spaltenanzahl
const cfg = {
    1: { nameMax: 38, nameMin: 26, title: 24 },
    2: { nameMax: 32, nameMin: 22, title: 21 },
    3: { nameMax: 26, nameMin: 18, title: 17 },
    4: { nameMax: 22, nameMin: 15, title: 15 },
    5: { nameMax: 18, nameMin: 13, title: 13 },
    6: { nameMax: 15, nameMin: 11, title: 11 },
}[colCount] || { nameMax: 20, nameMin: 14, title: 13 };

document.querySelectorAll('.box').forEach(box => {
    const boxH = box.offsetHeight;

    // Name: Startgröße aus Box-Höhe, damit große Boxen großen Text haben
    const nameStart = Math.min(Math.max(Math.floor(boxH * 0.30), cfg.nameMin + 2), 44);
    const nameEl = box.querySelector('.name');
    let size = nameStart;
    nameEl.style.fontSize = size + 'px';
    nameEl.style.whiteSpace = 'nowrap';
    while (nameEl.scrollWidth > nameEl.offsetWidth && size > cfg.nameMin) {
        nameEl.style.fontSize = --size + 'px';
    }
    if (nameEl.scrollWidth > nameEl.offsetWidth) {
        nameEl.style.whiteSpace = 'normal';
        nameEl.style.fontSize = cfg.nameMin + 'px';
    }

    // Titel: immer gleiche Größe (spaltenbasiert), bei Überlauf 2 Zeilen
    const titleEl = box.querySelector('.title');
    titleEl.style.fontSize = cfg.title + 'px';
    titleEl.style.whiteSpace = 'nowrap';
    if (titleEl.scrollWidth > titleEl.offsetWidth) {
        titleEl.style.whiteSpace = 'normal';
    }
});
</script>

</body>
</html>
